DATABASE_URL=postgresql://postgres:mysecret@localhost:5432/mydb
JWT_SECRET=secret
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

OAUTH_CALLBACK_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

PORT=5000
NODE_ENV=development

# Auto-moderation threshold (0-1). Posts above this are auto-flagged
AUTO_FLAG_THRESHOLD=0.7
# Posts above this are auto-removed
AUTO_REMOVE_THRESHOLD=0.9

# GEMINI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

#CLOUDINARY
CLOUDINARY_URL=cloudinary://<>:<>@<>